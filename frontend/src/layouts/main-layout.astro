---
import Header from '../components/header.astro';
import DashboardNav from '../components/main-dashboard/nav.astro';
import Footer from '../components/footer.astro';
import Cursor from '../components/cursor.astro';
import '../styles/global.css';
const { title, description, canonical, og_image = '/opengraph.png', useDashboardNav = false } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.creworklabs.com';
const og_image_absolute = og_image.startsWith('http') ? og_image : `${siteUrl}${og_image}`;

const isHomePage = !canonical || canonical === siteUrl || canonical === `${siteUrl}/`;
const breadcrumbSchema = !isHomePage ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": title ? title.split('|')[0].trim() : "Page",
      "item": canonical
    }
  ]
} : null;
---

<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@1&family=Inter:wght@100..900&family=Chakra+Petch:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KSN3EWDFTD"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-KSN3EWDFTD');
    </script>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="llms" href="/llms.txt" />
    <title>
      {title}
    </title>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={og_image_absolute} />
    <meta property="og:image:secure" content={og_image_absolute} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={og_image_absolute} />

    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}

    <script src="reb2b.js"></script>
    <slot name="head" />
  </head>
  <body class="overflow-x-hidden">
    <Cursor />
    {useDashboardNav ? <DashboardNav /> : <Header />}
    <main class="relative">
      <section
        class="relative -z-20 mx-auto h-10 w-[92%] max-w-5xl border-x border-[#F1F1F1] sm:h-12 sm:w-10/12 lg:w-9/12"
      >
      </section>
      <slot />
    </main>
    <Footer />
  </body>
</html>
