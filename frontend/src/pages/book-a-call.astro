---
import MainLayout from '../layouts/main-layout.astro';
import CalendlyWidget from '../components/booking/CalendlyWidget';

const title = "Book a Call | Crework Labs";
const description = "Schedule a 30-minute quick catchup with Crework Labs to discuss your project requirements, timeline, and pricing.";
const canonical = "https://www.creworklabs.com/book-a-call";
---

<MainLayout title={title} description={description} canonical={canonical} hideHeaderFooter={true} hideCustomCursor={true}>
  <div class="w-full min-h-screen bg-[#F8FAFC]">
    <CalendlyWidget client:load />
  </div>
</MainLayout>
