---
import Nav from '../components/main-dashboard/nav.astro';
import Hero from '../components/main-dashboard/hero.astro';
import Cards from '../components/main-dashboard/cards.astro';
import Cta from '../components/main-dashboard/cta.astro';
import Footer from '../components/footer.astro';

import '../styles/dashboard/main-dashboard.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Crework Dashboard" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@1&family=Inter:wght@100..900&family=Chakra+Petch:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <title>Crework Dashboard</title>

    <!-- JSON-LD Structured Data for SEO & AEO -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://creworklabs.com/#organization",
          "name": "Crework Labs",
          "url": "https://creworklabs.com",
          "logo": {
            "@type": "ImageObject",
            "url": "https://creworklabs.com/logo.svg"
          },
          "sameAs": [
            "https://x.com/CreworkHQ",
            "https://www.linkedin.com/school/creworklabss/"
          ],
          "description": "Leading agency building custom software, agentic AI systems, and MVPs for startups and high-growth companies."
        },
        {
          "@type": "WebSite",
          "@id": "https://creworklabs.com/#website",
          "url": "https://creworklabs.com",
          "name": "Crework Labs",
          "publisher": {
            "@id": "https://creworklabs.com/#organization"
          }
        }
      ]
    })} />
  </head>
  <body>
    <div class="landing-page">
      <!-- Custom Cursor -->
      <div class="custom-cursor" id="custom-cursor">
        <div class="cursor-dot"></div>
        <svg class="cursor-arrow" width="20" height="20" viewBox="0 0 24 24" fill="white">
          <path d="M4 0l16 16h-6.8l3.8 8-2.6 1.2-3.8-8-5.4 5.2z" />
        </svg>
      </div>
      <div class="cursor-trail" id="cursor-trail"></div>

      <Nav />
      <div class="grid-wrapper">
        <!-- Decorative Grid Lines -->
        <div class="grid-line grid-line--top"></div>
        <div class="grid-line grid-line--bottom"></div>
        <div class="grid-line grid-line--left"></div>
        <div class="grid-line grid-line--right"></div>

        <!-- Decorative Corner Nodes -->
        <div class="grid-node grid-node--tl"></div>
        <div class="grid-node grid-node--tr"></div>
        <div class="grid-node grid-node--bl"></div>
        <div class="grid-node grid-node--br"></div>

        <Hero />
        <Cards />
        <Cta />
      </div>
      <div class="fade-in-footer w-full" style="opacity: 0;">
        <Footer />
      </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        // --- CUSTOM CURSOR ---
        const cursor = document.getElementById('custom-cursor');
        const trail = document.getElementById('cursor-trail');
        const mouse = { x: 0, y: 0 };
        const trailPos = { x: 0, y: 0 };

        const handleMouseMove = (e) => {
          mouse.x = e.clientX;
          mouse.y = e.clientY;

          if (cursor) {
            cursor.style.left = `${e.clientX}px`;
            cursor.style.top = `${e.clientY}px`;
          }

          // Check if hovering over interactive elements
          const target = e.target as HTMLElement;
          const isBtn = target.closest('.header-cta, .card-btn, .footer-link, .footer-email, .nav-link, button, a, [role="button"]');
          const isText = target.closest('p, h1, h2, h3, span, .social-icon, .footer-tagline, .footer-brand-name');
          
          if (isText && !isBtn) {
            cursor?.classList.add('is-hovering');
          } else {
            cursor?.classList.remove('is-hovering');
          }

          if (isBtn) {
            cursor?.classList.add('is-btn-hovering');
            if (target.closest('.card-btn--dark') || target.closest('.header-cta')) {
              cursor?.classList.add('btn-dark');
              cursor?.classList.remove('btn-light');
            } else {
              cursor?.classList.add('btn-light');
              cursor?.classList.remove('btn-dark');
            }
          } else {
            cursor?.classList.remove('is-btn-hovering', 'btn-light', 'btn-dark');
          }
        };

        let animFrameId;
        const updateTrail = () => {
          const dx = mouse.x - trailPos.x;
          const dy = mouse.y - trailPos.y;
          trailPos.x += dx * 0.15;
          trailPos.y += dy * 0.15;

          if (trail) {
            trail.style.left = `${trailPos.x}px`;
            trail.style.top = `${trailPos.y}px`;
          }
          animFrameId = requestAnimationFrame(updateTrail);
        };

        window.addEventListener('mousemove', handleMouseMove);
        animFrameId = requestAnimationFrame(updateTrail);
        // Reveal text words
        const words = document.querySelectorAll('.fade-word');
        words.forEach((word) => {
          word.classList.add('visible');
        });

        // Subtitle fade
        setTimeout(() => {
          const subtitle = document.querySelector('.fade-in-subtitle');
          if (subtitle) {
            subtitle.classList.add('visible');
          }
        }, 1500);

        // CTA fade
        setTimeout(() => {
          const cta = document.querySelector('.fade-in-cta');
          if (cta) {
            cta.classList.add('visible');
          }
        }, 2000);

        // Footer fade
        setTimeout(() => {
          const footer = document.querySelector('.fade-in-footer');
          if (footer) {
            footer.style.animation = 'fade-in-simple 1s ease-out forwards';
          }
        }, 0);
      });
    </script>
    <script>
      import { setupFunnelAutoTracking } from '../utils/mixpanel';
      setupFunnelAutoTracking({
        pageName: 'homepage',
      });
    </script>
  </body>
</html>