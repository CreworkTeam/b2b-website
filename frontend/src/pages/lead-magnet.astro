---
import { LandingPage } from '../components/founderos/landing/LandingPage';
import { ViewTransitions } from 'astro:transitions';
import Cursor from '../components/cursor.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Founder OS</title>
    <ViewTransitions />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=Manrope:wght@400;500;600;700&family=DM+Mono:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style is:global>
      :root {
        --font-space-grotesk: 'Space Grotesk', sans-serif;
        --font-instrument-serif: 'Instrument Serif', serif;
        --font-manrope: 'Manrope', sans-serif;
        --font-dm-mono: 'DM Mono', monospace;
        --font-inter: 'Inter', sans-serif;
      }
      .font-space-grotesk { font-family: var(--font-space-grotesk); }
      .font-instrument-serif { font-family: var(--font-instrument-serif); }
      .font-manrope { font-family: var(--font-manrope); }
      .font-dm-mono { font-family: var(--font-dm-mono); }
      .font-inter { font-family: var(--font-inter); }

      /* Hero blueprint card — painted arrow */
      @keyframes arrowFlowDown {
        to { stroke-dashoffset: -14; }
      }
      @keyframes arrowBob {
        0%, 100% { transform: translateY(0px); }
        50%       { transform: translateY(3px); }
      }
      .arrow-flow { animation: arrowFlowDown 0.55s linear infinite; }
      .arrow-bob  { animation: arrowBob 1.4s ease-in-out infinite; }
    </style>
  </head>
  <body>
    <LandingPage client:load />
    <Cursor />
  </body>
</html>
