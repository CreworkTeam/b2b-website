---
import { LandingPage } from '../components/founderos/landing/LandingPage';
import { ViewTransitions } from 'astro:transitions';
import Cursor from '../components/cursor.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Founder OS</title>

    <!-- JSON-LD Structured Data for SoftwareApplication & Service -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "SoftwareApplication",
          "@id": "https://creworklabs.com/lead-magnet#app",
          "name": "Crework Founder OS - Idea Evaluator",
          "url": "https://creworklabs.com/lead-magnet",
          "applicationCategory": "BusinessApplication",
          "operatingSystem": "All",
          "description": "Evaluate and validate your startup idea, MVP scope, and product-market fit.",
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD"
          },
          "provider": {
            "@type": "Organization",
            "name": "Crework Labs",
            "url": "https://creworklabs.com"
          }
        }
      ]
    })} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ViewTransitions />
    <style is:global>
      :root {
        --font-space-grotesk: 'Chakra Petch', sans-serif;
        --font-instrument-serif: 'Instrument Serif', serif;
        --font-manrope: 'Manrope', sans-serif;
        --font-dm-mono: 'DM Mono', monospace;
        --font-inter: 'Inter', sans-serif;
      }
      .font-space-grotesk { font-family: var(--font-space-grotesk); }
      .font-instrument-serif { font-family: var(--font-instrument-serif); }
      .font-manrope { font-family: var(--font-manrope); }
      .font-dm-mono { font-family: var(--font-dm-mono); }
      .font-inter { font-family: var(--font-inter); }

      /* Hero blueprint card — painted arrow */
      @keyframes arrowFlowDown {
        to { stroke-dashoffset: -14; }
      }
      @keyframes arrowBob {
        0%, 100% { transform: translateY(0px); }
        50%       { transform: translateY(3px); }
      }
      .arrow-flow { animation: arrowFlowDown 0.55s linear infinite; }
      .arrow-bob  { animation: arrowBob 1.4s ease-in-out infinite; }
    </style>
  </head>
  <body>
    <LandingPage client:load />
    <Cursor />
    <script>
      import { trackFounderOSLandingViewed } from '../utils/mixpanel';
      trackFounderOSLandingViewed();
    </script>
  </body>
</html>

