---
import { ReportPage } from '../../components/founderos/report/ReportPage';
import '../../styles/founderos.css';
import { ViewTransitions } from 'astro:transitions';
import Cursor from '../../components/cursor.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KSN3EWDFTD"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-KSN3EWDFTD');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Founder OS Report | Crework Labs</title>
    <meta name="description" content="Detailed Founder OS diagnostic report generated by Crework Labs." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://www.creworklabs.com/lead-magnet/report" />
    <meta property="og:title" content="Founder OS Report | Crework Labs" />
    <meta property="og:description" content="Detailed Founder OS diagnostic report generated by Crework Labs." />
    <meta property="og:image" content="https://www.creworklabs.com/opengraph.png" />
    <meta property="og:url" content="https://www.creworklabs.com/lead-magnet/report" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Founder OS Report | Crework Labs" />
    <meta name="twitter:description" content="Detailed Founder OS diagnostic report generated by Crework Labs." />
    <meta name="twitter:image" content="https://www.creworklabs.com/opengraph.png" />
    <ViewTransitions />
    <style is:global>
      :root {
        --font-geist-sans: 'Chakra Petch', sans-serif;
        --font-geist-mono: 'DM Mono', monospace;
        --font-instrument-serif: 'Instrument Serif', serif;
        --font-manrope: 'Chakra Petch', sans-serif;
        --font-inter: 'Chakra Petch', sans-serif;
      }
      body {
        background-color: #ffffff;
        margin: 0;
        font-family: var(--font-inter);
      }
      .font-space-grotesk { font-family: 'Chakra Petch', sans-serif; }
      
      /* Globally scale up compact font sizes to improve Chakra Petch legibility */
      .text-\[9px\] { font-size: 11px !important; }
      .text-\[10px\] { font-size: 12px !important; }
      .text-\[11px\] { font-size: 13px !important; }
      .text-\[12px\] { font-size: 14px !important; }
      .text-\[13px\] { font-size: 15px !important; }
      .text-\[14px\] { font-size: 16px !important; }
      .text-\[15px\] { font-size: 17px !important; }
      .text-sm { font-size: 15px !important; }
      .text-xs { font-size: 13px !important; }

      /* Additional helper classes */
      .truncate {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
    </style>
  </head>
  <body>
    <ReportPage client:load />
    <Cursor />
  </body>
</html>
