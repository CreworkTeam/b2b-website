---
import { QuizPageView } from '../../components/founderos/quiz/QuizPageView';
import '../../styles/founderos.css';
import { ViewTransitions } from 'astro:transitions';
import Cursor from '../../components/cursor.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KSN3EWDFTD"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-KSN3EWDFTD');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Founder OS Quiz | Crework Labs</title>
    <link rel="preload" href="/fonts/chakra-petch/chakra-petch-v1-700.woff2" as="font" type="font/woff2" crossorigin />
    <meta name="description" content="Take the Founder OS Quiz by Crework Labs to evaluate your startup idea, architecture readiness, and growth strategy." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://www.creworklabs.com/lead-magnet/quiz" />
    <meta property="og:title" content="Founder OS Quiz | Crework Labs" />
    <meta property="og:description" content="Take the Founder OS Quiz by Crework Labs to evaluate your startup idea, architecture readiness, and growth strategy." />
    <meta property="og:image" content="https://www.creworklabs.com/opengraph.png" />
    <meta property="og:url" content="https://www.creworklabs.com/lead-magnet/quiz" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Founder OS Quiz | Crework Labs" />
    <meta name="twitter:description" content="Take the Founder OS Quiz by Crework Labs to evaluate your startup idea, architecture readiness, and growth strategy." />
    <meta name="twitter:image" content="https://www.creworklabs.com/opengraph.png" />
    <ViewTransitions />
    <style is:global>
      :root {
        --font-geist-sans: 'Inter', sans-serif;
        --font-geist-mono: 'DM Mono', monospace;
        --font-instrument: 'Instrument Serif', serif;
        --font-manrope: 'Manrope', sans-serif;
        --font-inter: 'Inter', sans-serif;
      }
      body {
        background-color: #ffffff;
        margin: 0;
        font-family: var(--font-inter);
      }
      .font-space-grotesk { font-family: 'Chakra Petch', sans-serif; }
      .font-instrument { font-family: var(--font-instrument); }
      .font-manrope { font-family: var(--font-manrope); }
      .font-dm-mono { font-family: var(--font-dm-mono); }
      .font-inter { font-family: var(--font-inter); }

      /* Pulse dot for classifier */
      @keyframes pulseDot {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
      }
      .pulse-dot {
        animation: pulseDot 1s ease-in-out infinite;
      }
    </style>
  </head>
  <body>
    <QuizPageView client:load titleFontClass="font-space-grotesk" bodyFontClass="font-inter" />
    <Cursor />
  </body>
</html>
