---
const teamData = [
  {
    initials: 'SJ',
    name: 'Shikshita Juyal',
    role: 'Founder & CEO',
    company: 'CREWORK | UPenn',
    img: '/team/shikshita.png',
    companyLogo: '/logos/crework.png',
    linkedin: 'https://www.linkedin.com/in/shikshita-juyal/'
  },
  {
    initials: 'HS',
    name: 'Herumb Shandilya',
    role: 'Data Science Partner',
    company: 'STANFORD',
    img: '/team/herumb.png',
    companyLogo: '/logos/standford.png',
    linkedin: 'https://www.linkedin.com/in/herumb-shandilya'
  },
  {
    initials: 'TC',
    name: 'Tharun Chowary',
    role: 'Tech Partner',
    company: 'AMAZON',
    img: '/team/tharun.png',
    companyLogo: '/logos/amazon.png',
    linkedin: 'https://www.linkedin.com/in/tharun0102/'
  },
  {
    initials: 'ID',
    name: 'Ishan Dutta',
    role: 'ML Partner',
    company: 'ADOBE',
    img: '/team/ishan.png',
    companyLogo: '/logos/adobe.png',
    linkedin: 'https://www.linkedin.com/in/ishandutta0098/'
  },
  {
    initials: 'DJ',
    name: 'Dinkar Juyal',
    role: 'Data Science Partner',
    company: 'Meta | UC BERKELEY',
    img: '/team/dinkar.png',
    companyLogo: '/logos/UCBerkley.png',
    linkedin: 'https://www.linkedin.com/in/dinkarjuyal1/'
  },
  {
    initials: 'ML',
    name: 'Mitali Laroia',
    role: 'Tech Partner',
    company: 'WALMART',
    img: '/team/mitali.png',
    companyLogo: '/Walmart.png',
    linkedin: 'https://www.linkedin.com/in/mitali-laroia-b52763191/'
  }
];
---
<section class="team">
  <div class="container">
    <div class="sec-head reveal"><span class="sec-index">03 / Team</span></div>
    <h2 class="reveal">Meet the Team</h2>
    <div class="team-grid">
      {teamData.map((m) => (
        <div class="member reveal">
          <div class="member-header">
            <h3 class="member-name">{m.name}</h3>
            <img 
              src={m.companyLogo} 
              alt={m.company}
              class="company-badge"
              loading="lazy"
              width="80"
              height="28"
            />
          </div>
          
          <div class="avatar-container">
            <img
              src={m.img}
              alt={m.name}
              class="avatar-img"
              loading="lazy"
              width="300"
              height="300"
            />
          </div>
          
          <div class="member-footer">
            <div class="meta">
              <p class="role">{m.role}</p>
              <p class="cred">{m.company}</p>
            </div>
            <a 
              href={m.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="linkedin-link"
            >
              <img
                src="/icons/linkedin.png"
                alt="LinkedIn"
                class="linkedin-icon"
                loading="lazy"
                width="20"
                height="20"
              />
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
