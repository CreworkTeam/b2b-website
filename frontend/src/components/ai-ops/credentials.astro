---
const credsList = [
  { name: 'Stanford', logo: '/logos/standford.png' },
  { name: 'UPenn', logo: '/logos/upenn.svg' },
  { name: 'Meta', logo: '/logos/meta.svg' },
  { name: 'Amazon', logo: '/logos/amazon.svg' },
  { name: 'Adobe', logo: '/logos/adobe.png' },
  { name: 'UC Berkeley', logo: '/logos/UCBerkley.png' },
  { name: 'Walmart', logo: '/Walmart.png' },
  { name: 'Springworks', logo: '/logos/springworks.png' }
];
---
<div class="creds">
  <div class="container">
    <p class="creds-label reveal">BUILT BY A TEAM FROM</p>
  </div>
  <div class="marquee reveal" aria-label="Team credentials">
    <div class="marquee-track">
      {credsList.map((c) => (
        (c.name === 'Amazon' || c.name === 'Meta') ? (
          <span class="inline-flex items-center">
            <img src={c.logo} alt={c.name} class="h-[28px] md:h-[34px] w-auto opacity-70 hover:opacity-100 transition-opacity filter invert grayscale mix-blend-screen" style="vertical-align: middle; object-fit: contain;" />
          </span>
        ) : (
          <span class="inline-flex items-center gap-3">
            <img src={c.logo} alt={c.name} class="h-[28px] md:h-[34px] w-auto opacity-70 hover:opacity-100 transition-opacity filter invert grayscale mix-blend-screen" style="vertical-align: middle; object-fit: contain;" />
            <span style="margin: 0;">{c.name}</span>
          </span>
        )
      ))}
      {credsList.map((c) => (
        (c.name === 'Amazon' || c.name === 'Meta') ? (
          <span aria-hidden="true" class="inline-flex items-center">
            <img src={c.logo} alt={c.name} class="h-[28px] md:h-[34px] w-auto opacity-70 hover:opacity-100 transition-opacity filter invert grayscale mix-blend-screen" style="vertical-align: middle; object-fit: contain;" />
          </span>
        ) : (
          <span aria-hidden="true" class="inline-flex items-center gap-3">
            <img src={c.logo} alt={c.name} class="h-[28px] md:h-[34px] w-auto opacity-70 hover:opacity-100 transition-opacity filter invert grayscale mix-blend-screen" style="vertical-align: middle; object-fit: contain;" />
            <span style="margin: 0;">{c.name}</span>
          </span>
        )
      ))}
    </div>
  </div>
</div>
