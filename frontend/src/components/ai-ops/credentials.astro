---
const credsList = [
  { name: 'Stanford', logo: '/logos/standford.png', slug: 'stanford' },
  { name: 'UPenn', logo: '/logos/upenn.png', slug: 'upenn' },
  { name: 'Meta', logo: '/logos/meta.png', slug: 'meta' },
  { name: 'Amazon', logo: '/logos/amazon.png', slug: 'amazon' },
  { name: 'Adobe', logo: '/logos/adobe.png', slug: 'adobe' },
  { name: 'UC Berkeley', logo: '/logos/berkeley.png', slug: 'berkeley' },
  { name: 'Walmart', logo: '/logos/walmart.png', slug: 'walmart' },
  { name: 'Springworks', logo: '/logos/springworks.png', slug: 'springworks' }
];
---
<div class="creds">
  <div class="container">
    <p class="creds-label reveal">BUILT BY A TEAM FROM</p>
  </div>
  <div class="marquee reveal" aria-label="Team credentials">
    <div class="marquee-track py-4">
      {credsList.map((c) => (
        <div class="cred-item group cursor-pointer inline-flex items-center gap-4 px-6 md:px-10 py-2">
          {c.logo && <img src={c.logo} alt={c.name} class="cred-logo h-[34px] md:h-[46px] w-auto min-w-[34px] object-contain" />}
          <p class="cred-name font-bold tracking-wide font-sans m-0 p-0">{c.name}</p>
        </div>
      ))}
      {credsList.map((c) => (
        <div aria-hidden="true" class="cred-item group cursor-pointer inline-flex items-center gap-4 px-6 md:px-10 py-2">
          {c.logo && <img src={c.logo} alt={c.name} class="cred-logo h-[34px] md:h-[46px] w-auto min-w-[34px] object-contain" />}
          <p class="cred-name font-bold tracking-wide font-sans m-0 p-0">{c.name}</p>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .cred-item {
    transition: all 0.3s ease;
  }
  .cred-logo {
    opacity: 0.55;
    filter: grayscale(100%) brightness(1.1);
    transition: all 0.3s ease;
  }
  .cred-name {
    font-size: 32px;
    color: #8E8E93;
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 700;
    line-height: 1.2;
    transition: all 0.3s ease;
  }
  @media (min-width: 768px) {
    .cred-name {
      font-size: 44px;
    }
  }
  .cred-item:hover .cred-logo {
    opacity: 1;
    filter: grayscale(100%) brightness(2.2);
  }
  .cred-item:hover .cred-name {
    color: #FFFFFF;
    text-shadow: 0 0 12px rgba(255, 255, 255, 0.25);
  }
</style>
