---
const credsList = [
  { name: 'Stanford', logo: '/logos/stanford.png', slug: 'stanford' },
  { name: 'UPenn', logo: '/logos/upenn.png', slug: 'upenn' },
  { name: 'Meta', logo: '/logos/meta.png', slug: 'meta' },
  { name: 'Amazon', logo: '/logos/amazon.png', slug: 'amazon' },
  { name: 'Adobe', logo: '/logos/adobe.png', slug: 'adobe' },
  { name: 'UC Berkeley', logo: '/logos/berkeley.png', slug: 'berkeley' },
  { name: 'Walmart', logo: '/logos/walmart.png', slug: 'walmart' },
  { name: 'Springworks', logo: '/logos/springworks.png', slug: 'springworks' }
];
---
<div class="creds">
  <div class="container">
    <p class="creds-label reveal">BUILT BY A TEAM FROM</p>
  </div>
  <div class="marquee reveal" aria-label="Team credentials">
    <div class="marquee-track py-3">
      {credsList.map((c) => (
        <div class="inline-flex items-center gap-3.5 px-5 md:px-8 py-1.5">
          <img src={c.logo} alt={c.name} class="h-[26px] md:h-[32px] w-auto min-w-[26px] object-contain opacity-90 transition-opacity" />
          <p class="font-bold text-white tracking-wide font-sans m-0 p-0 leading-normal" style="font-size: 24px !important; color: #FFFFFF !important; line-height: 1.4 !important; font-family: 'Chakra Petch', sans-serif !important; font-weight: 700 !important;">{c.name}</p>
        </div>
      ))}
      {credsList.map((c) => (
        <div aria-hidden="true" class="inline-flex items-center gap-3.5 px-5 md:px-8 py-1.5">
          <img src={c.logo} alt={c.name} class="h-[26px] md:h-[32px] w-auto min-w-[26px] object-contain opacity-90 transition-opacity" />
          <p class="font-bold text-white tracking-wide font-sans m-0 p-0 leading-normal" style="font-size: 24px !important; color: #FFFFFF !important; line-height: 1.4 !important; font-family: 'Chakra Petch', sans-serif !important; font-weight: 700 !important;">{c.name}</p>
        </div>
      ))}
    </div>
  </div>
</div>
