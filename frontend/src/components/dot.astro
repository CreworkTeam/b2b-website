---
const { class: className, isWhite = false } = Astro.props;
---

<div
  class:list={['absolute z-20 m-0 h-3 w-3 rounded-full sm:h-7 sm:w-7', className]}
  style={
    isWhite 
      ? "background:linear-gradient(180deg, #E5E5E5 0%, #CCCCCC 100%);box-shadow: 0px 1.88px 6px 1.5px #0000001F, 0px 4px 6px -2px #00000040;" 
      : "background:linear-gradient(180deg, #454545 0%, #252525 100%);box-shadow: 0px 1.88px 6px 1.5px #0000001F, 0px 4px 6px -2px #00000040, 0px 0px 1px 2px #FFFFFF0D, 0px 0px 1px 1px #FFFFFF12;"
  }
>
</div>
