---
import { Image } from 'astro:assets';
import Section from '../section.astro';
import { BOOK_CALL } from '@/constants';
---

<Section id="pricing" data-section="pricing">
  <div class="space-y-6 text-center">
    <div class="space-y-3">
      <h2 class="font-semibold text-3xl md:text-4xl">One flat price to launch ⚡</h2>
      <p class="text-lg text-gray-600">No hourly billing. No scope creep invoices. You know the cost before we write a line of code.</p>
    </div>
    <div class="mx-auto flex w-full max-w-[500px] flex-col rounded-[2rem] bg-[#0A0A0A] p-6 sm:p-8 text-center text-white shadow-2xl">
      <div class="flex flex-col items-center justify-center space-y-3">
        <h2 class="text-balance text-3xl font-bold text-white tracking-tight">MVP Development</h2>
        
        <!-- Divider with dot -->
        <div class="flex w-24 items-center justify-center gap-2">
          <div class="h-[1px] w-full bg-[#333333]"></div>
          <div class="size-1 rounded-full bg-[#666666]"></div>
          <div class="h-[1px] w-full bg-[#333333]"></div>
        </div>
        
        <p class="text-balance text-[#A0A0A0] text-sm sm:text-base">
          For founders ready to launch a web or mobile app.
        </p>
      </div>
      
      <div class="mt-6 mb-6 flex flex-col items-center justify-center space-y-1">
        <div class="flex items-center gap-3 text-[#888888] font-medium text-sm">
          <div class="h-[1px] w-8 bg-[#333333]"></div>
          <span>Starts from</span>
          <div class="h-[1px] w-8 bg-[#333333]"></div>
        </div>
        <h2 class="text-white text-5xl font-bold tracking-tighter">$3000</h2>
      </div>
      
      <!-- Inner bordered checklist container -->
      <div class="flex flex-col rounded-2xl border border-[#222222] bg-[#0F0F0F] p-1 mb-6">
        {
          [
            "A working web or mobile app in your users' hands in 3 to 4 weeks",
            'Scoping session to pressure test the idea before we build',
            'Market research and competitor analysis',
            'Brand identity and full UI/UX design',
            'End to end development, launch and deployment',
            'Weekly demos so you always know where things stand',
            'You own all code, IP and infrastructure from day one'
          ].map((item, i, arr) => (
            <div class={`flex items-center gap-3 p-3 ${i !== arr.length - 1 ? 'border-b border-[#222222]' : ''}`}>
              <div class="flex size-6 shrink-0 items-center justify-center rounded-full bg-[#1E1E1E] border border-[#333333]">
                <Image
                  src="/icons/tick-white.svg"
                  alt="tick"
                  class="size-2.5"
                  width={10}
                  height={10}
                />
              </div>
              <div class="flex-1 text-left text-sm text-[#E0E0E0] leading-snug">{item}</div>
            </div>
          ))
        }
      </div>
      
      <div class="flex items-center justify-center">
        <a
          href={BOOK_CALL}
          target="_blank"
          class="block w-full cursor-pointer rounded-xl bg-white px-8 py-3 text-base font-semibold leading-tight text-black transition-transform hover:scale-[1.02] sm:w-auto min-w-[200px]"
        >
          Get your MVP
        </a>
      </div>
    </div>
    
    <div class="mx-auto max-w-2xl mt-8 pt-8 border-t border-gray-200">
      <p class="text-[#666666] text-balance">
        After launch, most founders keep us on as their product team. Same setup, same shared goal: paying users. We scope that together on your call.
      </p>
    </div>
  </div>
</Section>
