---
---
<!-- Custom Cursor -->
<div class="custom-cursor" id="custom-cursor">
  <div class="cursor-dot"></div>
  <svg class="cursor-arrow" width="20" height="20" viewBox="0 0 24 24" fill="white">
    <path d="M4 0l16 16h-6.8l3.8 8-2.6 1.2-3.8-8-5.4 5.2z" />
  </svg>
</div>
<div class="cursor-trail" id="cursor-trail"></div>

<style is:global>
  body, a, button, .nav-link, * {
    cursor: none !important;
  }

  /* Custom Cursor */
  .custom-cursor {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 999999;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    mix-blend-mode: difference;
    transition: opacity 0.2s;
  }

  .cursor-dot {
    width: 10px;
    height: 10px;
    background-color: #ffffff;
    border: 1px solid transparent;
    border-radius: 50%;
    transition: opacity 0.2s, transform 0.2s, background-color 0.2s, border-color 0.2s;
  }

  .cursor-arrow {
    display: none;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-30%, -30%);
  }

  .custom-cursor.is-hovering .cursor-dot {
    transform: scale(4);
    background-color: transparent;
    border-color: rgba(255, 255, 255, 0.4);
  }

  .custom-cursor.is-btn-hovering {
    mix-blend-mode: normal;
  }

  .custom-cursor.is-btn-hovering .cursor-dot {
    display: none;
  }

  .custom-cursor.is-btn-hovering .cursor-arrow {
    display: block;
  }

  .custom-cursor.is-btn-hovering.btn-light .cursor-arrow {
    fill: #111111;
  }

  .custom-cursor.is-btn-hovering.btn-dark .cursor-arrow {
    fill: #ffffff;
  }

  /* Cursor Trail Ring */
  .cursor-trail {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 999998;
    width: 24px;
    height: 24px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    mix-blend-mode: difference;
    transition: opacity 0.3s, transform 0.3s;
  }

  .custom-cursor.is-hovering+.cursor-trail,
  .custom-cursor.is-btn-hovering+.cursor-trail {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
  }

  @media (max-width: 1024px) {
    body, a, button, .nav-link, * {
      cursor: auto !important;
    }
    .custom-cursor,
    .cursor-trail {
      display: none !important;
    }
  }
</style>

<script is:inline>
  (function() {
    if (window._cursorBound) return;
    window._cursorBound = true;

    const mouse = { x: 0, y: 0 };
    const trailPos = { x: 0, y: 0 };

    window.addEventListener('mousemove', (e) => {
      mouse.x = e.clientX;
      mouse.y = e.clientY;

      const cursor = document.getElementById('custom-cursor');
      if (cursor) {
        cursor.style.left = `${e.clientX}px`;
        cursor.style.top = `${e.clientY}px`;
      }

      // Check if hovering over interactive elements
      const target = e.target;
      if (!target || !target.closest) return;
      
      const isBtn = target.closest('.header-cta, .card-btn, .footer-link, .footer-email, .nav-link, .btn, button, a, [role="button"]');
      const isText = target.closest('p, h1, h2, h3, span, .social-icon, .footer-tagline, .footer-brand-name');
      
      if (isText && !isBtn) {
        cursor?.classList.add('is-hovering');
      } else {
        cursor?.classList.remove('is-hovering');
      }

      if (isBtn) {
        cursor?.classList.add('is-btn-hovering');
        const isDarkSection = target.closest('.bg-black, .hero, .end-card, .cases, .ai-ops-page');
        
        const btnText = isBtn.textContent?.toLowerCase() || '';
        const isWhiteArrow = 
          btnText.includes('book a free discovery call') ||
          btnText.includes('view live link') ||
          btnText.includes('view all case studies') ||
          btnText.includes('validate your idea for free') ||
          btnText.includes('more') ||
          btnText.includes("let's chat") ||
          btnText.includes('start quiz') ||
          btnText.includes('start your blueprint');

        const isThemeDarkCta = target.closest('.theme-dark .header-cta') || (target.closest('.header-cta') && target.closest('.theme-dark'));
        const isThemeDarkContainer = target.closest('.theme-dark');

        if (isThemeDarkCta) {
          cursor?.classList.add('btn-light');
          cursor?.classList.remove('btn-dark');
        } else if (target.closest('.card-btn--dark') || target.closest('.header-cta') || isDarkSection || isWhiteArrow || isThemeDarkContainer) {
          cursor?.classList.add('btn-dark');
          cursor?.classList.remove('btn-light');
        } else {
          cursor?.classList.add('btn-light');
          cursor?.classList.remove('btn-dark');
        }
      } else {
        cursor?.classList.remove('is-btn-hovering', 'btn-light', 'btn-dark');
      }
    });

    const updateTrail = () => {
      const trail = document.getElementById('cursor-trail');
      const dx = mouse.x - trailPos.x;
      const dy = mouse.y - trailPos.y;
      trailPos.x += dx * 0.15;
      trailPos.y += dy * 0.15;

      if (trail) {
        trail.style.left = `${trailPos.x}px`;
        trail.style.top = `${trailPos.y}px`;
      }
      requestAnimationFrame(updateTrail);
    };

    requestAnimationFrame(updateTrail);
  })();
</script>
