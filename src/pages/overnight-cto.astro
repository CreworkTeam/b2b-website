---
import MainLayout from '../layouts/main-layout.astro';
import Hero from '../components/home/hero.astro';
import OurImpact from '../components/home/impact.astro';
import Testimonials from '../components/home/testimonials.astro';
import OurPortfolio from '../components/home/portfolio.astro';
import CaseStudies from '../components/home/case-studies/case-studies.astro';
import Contact from '../components/home/contact.astro';
import Pricing from '@/components/home/pricing.astro';
import HowWeWork from '@/components/home/how-we-work.astro';
import MeetTheTeam from '@/components/home/meet-the-team.astro';
import Positioning from '@/components/home/positioning.astro';
import LeadMagnet from '@/components/home/lead-magnet.astro';

const schema = {
  "@context":"https://schema.org",
  "@graph":[
    {
      "@type":"Organization",
      "@id":"https://www.creworklabs.com/#organization",
      "name":"Crework Labs",
      "url":"https://www.creworklabs.com/",
      "logo":"https://www.creworklabs.com/logo.png",
      "description":"Crework Labs is an MVP development and product studio helping startup founders design, build, and launch scalable products fast.",
      "foundingDate":"2023",
      "contactPoint":{
        "@type":"ContactPoint",
        "contactType":"sales",
        "url":"https://www.creworklabs.com/#contact"
      },
      "sameAs":[
        "https://www.linkedin.com/company/creworklabs",
        "https://twitter.com/creworklabs"
      ]
    },
    {
      "@type":"WebSite",
      "@id":"https://www.creworklabs.com/#website",
      "url":"https://www.creworklabs.com/",
      "name":"Crework Labs",
      "publisher":{
        "@id":"https://www.creworklabs.com/#organization"
      }
    },
    {
      "@type":"Service",
      "serviceType":"MVP Development",
      "name":"MVP Development for Startups",
      "description":"End-to-end MVP development including market research, product design, and full-stack development to help startup founders launch fast.",
      "provider":{
        "@id":"https://www.creworklabs.com/#organization"
      },
      "areaServed":"Worldwide",
      "offers":{
        "@type":"Offer",
        "price":"3000",
        "priceCurrency":"USD",
        "priceSpecification":{
          "@type":"UnitPriceSpecification",
          "price":"3000",
          "priceCurrency":"USD",
          "unitText":"project"
        }
      }
    },
    {
      "@type":"Service",
      "serviceType":"Website Design & Development",
      "name":"Website Design & Development",
      "description":"Custom website design and development for founders and teams who want to launch a high-conversion website in 1 week.",
      "provider":{
        "@id":"https://www.creworklabs.com/#organization"
      },
      "areaServed":"Worldwide",
      "offers":{
        "@type":"Offer",
        "price":"800",
        "priceCurrency":"USD"
      }
    }
  ]
};

const faqSchema = {
  "@context":"https://schema.org",
  "@type":"FAQPage",
  "mainEntity":[
    {
      "@type":"Question",
      "name":"What is an MVP and why do I need one?",
      "acceptedAnswer":{
        "@type":"Answer",
        "text":"An MVP (Minimum Viable Product) is the simplest version of your product that solves a core problem for users. It helps you validate your idea, attract early users, and secure funding without spending months or large budgets on full-scale development."
      }
    },
    {
      "@type":"Question",
      "name":"How long does it take to build an MVP with Crework Labs?",
      "acceptedAnswer":{
        "@type":"Answer",
        "text":"Depending on the complexity, we can deliver an MVP in as little as 4-8 weeks. Website projects are typically completed within 4-5 business days. We focus on speed without compromising quality."
      }
    },
    {
      "@type":"Question",
      "name":"What industries does Crework Labs work with?",
      "acceptedAnswer":{
        "@type":"Answer",
        "text":"We work across multiple industries including Education, E-Commerce, Fintech, Healthcare, SaaS, and Enterprise Operations. Our team has delivered 25+ projects for clients across 9 industries."
      }
    },
    {
      "@type":"Question",
      "name":"What is included in the MVP development package?",
      "acceptedAnswer":{
        "@type":"Answer",
        "text":"Our MVP development package starts at $3000 and includes market research and competitor analysis, custom brand identity design, UI/UX design, end-to-end web or mobile app development, and project management with regular progress updates."
      }
    },
    {
      "@type":"Question",
      "name":"How is Crework Labs different from other development agencies?",
      "acceptedAnswer":{
        "@type":"Answer",
        "text":"Crework Labs combines AI-powered solutions with human expertise, specifically tailored for startup founders. We focus on rapid delivery, data-driven design, and scalable architecture so your product can grow with your business."
      }
    }
  ]
};
---

<MainLayout
  title="Crework Labs | MVP Development Studio for Startup Founders"
  description="Crework Labs is an MVP development studio helping startup founders design, build, and launch scalable products fast. Book a free strategy call."
  canonical="https://www.creworklabs.com"
  og_image="/opengraph.png?v=2"
  useDashboardNav={true}
>
  <link rel="preconnect" href="https://fonts.googleapis.com" slot="head" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head" />
  <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head"></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head"></script>
  
  <div class="cto-page">
    <!-- Custom Cursor (same as dashboard) -->
    <div class="custom-cursor" id="custom-cursor">
      <div class="cursor-dot"></div>
      <svg class="cursor-arrow" width="20" height="20" viewBox="0 0 24 24" fill="white">
        <path d="M4 0l16 16h-6.8l3.8 8-2.6 1.2-3.8-8-5.4 5.2z" />
      </svg>
    </div>
    <div class="cursor-trail" id="cursor-trail"></div>

    <Hero />
    <OurPortfolio />
    <Positioning />
    <Testimonials />
    <OurImpact />
    <CaseStudies />
    <LeadMagnet />
    <MeetTheTeam />
    <HowWeWork />
    <Pricing />
    <Contact />
  </div>

  <style is:global>
    .cto-page > * {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .cto-page > *.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Hide default cursor on overnight-cto page */
    html, body, a, button, .nav-link, * {
      cursor: none !important;
    }

    /* Custom Cursor — exact copy from dashboard */
    .custom-cursor {
      position: fixed;
      top: 0;
      left: 0;
      pointer-events: none;
      z-index: 9999;
      transform: translate(-50%, -50%);
      display: flex;
      align-items: center;
      justify-content: center;
      mix-blend-mode: difference;
    }

    .cursor-dot {
      width: 10px;
      height: 10px;
      background-color: #ffffff;
      border: 1px solid transparent;
      border-radius: 50%;
      transition: opacity 0.2s, transform 0.2s, background-color 0.2s, border-color 0.2s;
    }

    .cursor-arrow {
      display: none;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-30%, -30%);
    }

    .custom-cursor.is-hovering .cursor-dot {
      transform: scale(4);
      background-color: transparent;
      border-color: rgba(255, 255, 255, 0.4);
    }

    .custom-cursor.is-btn-hovering {
      mix-blend-mode: normal;
    }

    .custom-cursor.is-btn-hovering .cursor-dot {
      display: none;
    }

    .custom-cursor.is-btn-hovering .cursor-arrow {
      display: block;
    }

    .custom-cursor.is-btn-hovering.btn-light .cursor-arrow {
      fill: #111111;
    }

    .custom-cursor.is-btn-hovering.btn-dark .cursor-arrow {
      fill: #ffffff;
    }

    /* Cursor Trail Ring */
    .cursor-trail {
      position: fixed;
      top: 0;
      left: 0;
      pointer-events: none;
      z-index: 9998;
      width: 24px;
      height: 24px;
      border: 1px solid rgba(255, 255, 255, 0.4);
      border-radius: 50%;
      transform: translate(-50%, -50%);
      mix-blend-mode: difference;
      transition: opacity 0.3s, transform 0.3s;
    }

    .custom-cursor.is-hovering + .cursor-trail,
    .custom-cursor.is-btn-hovering + .cursor-trail {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.5);
    }
  </style>

  <script>
    import { setupButtonTracking } from '../utils/mixpanel';

    setupButtonTracking({
      pageName: 'LandingPage',
    });

    document.addEventListener("DOMContentLoaded", () => {
      // Scroll animation
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: "0px 0px -50px 0px"
      });

      const sections = document.querySelectorAll('.cto-page > *');
      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        // Check if the section is already in the viewport on load
        if (rect.top < window.innerHeight) {
          section.classList.add('is-visible');
        } else {
          observer.observe(section);
        }
      });

      // Custom Cursor — exact same logic as dashboard
      const cursor = document.getElementById('custom-cursor');
      const trail = document.getElementById('cursor-trail');
      const mouse = { x: 0, y: 0 };
      const trailPos = { x: 0, y: 0 };

      const handleMouseMove = (e) => {
        mouse.x = e.clientX;
        mouse.y = e.clientY;

        if (cursor) {
          cursor.style.left = `${e.clientX}px`;
          cursor.style.top = `${e.clientY}px`;
        }

        const target = e.target;
        const isText = target.closest('p, h1, h2, h3, span, a:not(.nav-link):not(.btn), li');
        const isBtn = target.closest('.btn, a.btn, button, .nav-link, .header-cta');

        if (isText && !isBtn) {
          cursor?.classList.add('is-hovering');
        } else {
          cursor?.classList.remove('is-hovering');
        }

        if (isBtn) {
          cursor?.classList.add('is-btn-hovering');
          const btnElement = target.closest('.btn, a.btn, button, .nav-link, .header-cta');
          const btnText = btnElement?.textContent?.trim() || "";
          const isWhiteArrow = 
            btnText.includes("Book a free discovery call") ||
            btnText.includes("View Live Link") ||
            btnText.includes("View All Case Studies") ||
            btnText.includes("Validate your idea for free") ||
            btnText.includes("More") ||
            btnText.includes("Let's Chat");

          if (target.closest('.btn-dark') || target.closest('.btn[style*="background: #000"], .btn[style*="background:#000"]') || target.closest('.header-cta') || isWhiteArrow) {
            cursor?.classList.add('btn-dark');
          } else {
            cursor?.classList.add('btn-light');
          }
        } else {
          cursor?.classList.remove('is-btn-hovering', 'btn-light', 'btn-dark');
        }
      };

      const updateTrail = () => {
        const dx = mouse.x - trailPos.x;
        const dy = mouse.y - trailPos.y;
        trailPos.x += dx * 0.15;
        trailPos.y += dy * 0.15;

        if (trail) {
          trail.style.left = `${trailPos.x}px`;
          trail.style.top = `${trailPos.y}px`;
        }
        requestAnimationFrame(updateTrail);
      };

      window.addEventListener('mousemove', handleMouseMove);
      requestAnimationFrame(updateTrail);
    });
  </script>
</MainLayout>
