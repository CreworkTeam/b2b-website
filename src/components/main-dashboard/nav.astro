---
export interface Props {
  theme?: 'light' | 'dark';
}
const { theme = 'light' } = Astro.props;
---
<header class={`header ${theme === 'dark' ? 'theme-dark' : ''}`}>
  <div class="header-container">
    <div class="header-logo">
      <a href="/" style="display:flex;align-items:center;" class="nav-link">
        <img src="/logo.svg" alt="Company Logo" class="header-logo-image" />
      </a>
    </div>

    <div class="header-right">
      <nav class="header-nav">
        <a href="/agentic-ai-systems" class="nav-link">Agentic AI systems</a>
        <a href="/overnight-cto" class="nav-link">Overnight CTO</a>
        <a href="/blog" class="nav-link">Blog</a>
      </nav>

      <a href="https://calendly.com/creworklabs/30mins" target="_blank" rel="noopener noreferrer" class="header-cta">
        Book a call
      </a>
    </div>
  </div>
</header>

<style is:global>
  .header {
    width: 100%;
    border-bottom: 1px solid #eaeaea;
    display: flex;
    justify-content: center;
    position: relative;
    z-index: 10;
    background: #ffffff;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    max-width: 1140px;
    padding: 16px 24px;
  }

  .header-logo {
    display: flex;
    align-items: center;
  }

  .header-logo-image {
    height: 28.5px;
    width: auto;
    object-fit: contain;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .header-nav {
    display: flex;
    gap: 32px;
    align-items: center;
  }

  .nav-link {
    font-size: 14px;
    color: #666666;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: #111111; 
  }

  .header-cta {
    background: #111111;
    color: white;
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s;
    text-decoration: none;
    display: inline-block;
  }

  .header-cta:hover {
    opacity: 0.85;
  }

  /* Dark Theme Overrides */
  .header.theme-dark {
    border-bottom-color: #333333;
    background: #0A0A0A;
  }

  .header.theme-dark .nav-link {
    color: #a1a1aa;
  }

  .header.theme-dark .nav-link:hover {
    color: #ffffff;
  }

  .header.theme-dark .header-cta {
    background: #ffffff;
    color: #111111;
  }

  .header.theme-dark .header-logo-image {
    filter: invert(1) brightness(2);
  }

  @media (max-width: 768px) {
    .header-container {
      flex-direction: column;
      gap: 16px;
    }
    .header-nav {
      gap: 16px;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>