---
import { BOOK_CALL } from '@/constants.ts';
---

<section class="section-container hero-grid-wrapper" data-section="hero">
  <!-- Interactive Grid Background (clipped inside section-container) -->
  <canvas id="hero-grid-canvas" class="hero-grid-canvas"></canvas>

  <!-- Corner dots (on top of grid) -->
  <div
    class="absolute left-0 top-0 z-20 h-3 w-3 -translate-x-1/2 -translate-y-1/2 rounded-full bg-gradient-to-b from-white to-[#ECECEC] p-[2px] sm:h-7 sm:w-7"
    style="box-shadow: 0px 0px 0.468888px 0.468888px rgba(0, 0, 0, 0.07), 0px 0px 0.468888px 1.40666px rgba(0, 0, 0, 0.05), 0px 5.62666px 6.09555px -2.81333px rgba(0, 0, 0, 0.25), 0px 1.87555px 7.50221px 1.87555px rgba(0, 0, 0, 0.12);"
  >
    <div class="h-full w-full rounded-full bg-gradient-to-b from-[#F4F4F4] to-[#FEFEFE]"></div>
  </div>
  <div
    class="absolute right-0 top-0 z-20 h-3 w-3 -translate-y-1/2 translate-x-1/2 rounded-full bg-gradient-to-b from-white to-[#ECECEC] p-[2px] sm:h-7 sm:w-7"
    style="box-shadow: 0px 0px 0.468888px 0.468888px rgba(0, 0, 0, 0.07), 0px 0px 0.468888px 1.40666px rgba(0, 0, 0, 0.05), 0px 5.62666px 6.09555px -2.81333px rgba(0, 0, 0, 0.25), 0px 1.87555px 7.50221px 1.87555px rgba(0, 0, 0, 0.12);"
  >
    <div class="h-full w-full rounded-full bg-gradient-to-b from-[#F4F4F4] to-[#FEFEFE]"></div>
  </div>
  <div
    class="absolute bottom-0 right-0 z-20 h-3 w-3 translate-x-1/2 translate-y-1/2 rounded-full bg-gradient-to-b from-white to-[#ECECEC] p-[2px] sm:h-7 sm:w-7"
    style="box-shadow: 0px 0px 0.468888px 0.468888px rgba(0, 0, 0, 0.07), 0px 0px 0.468888px 1.40666px rgba(0, 0, 0, 0.05), 0px 5.62666px 6.09555px -2.81333px rgba(0, 0, 0, 0.25), 0px 1.87555px 7.50221px 1.87555px rgba(0, 0, 0, 0.12);"
  >
    <div class="h-full w-full rounded-full bg-gradient-to-b from-[#F4F4F4] to-[#FEFEFE]"></div>
  </div>
  <div
    class="absolute bottom-0 left-0 z-20 h-3 w-3 -translate-x-1/2 translate-y-1/2 rounded-full bg-gradient-to-b from-white to-[#ECECEC] p-[2px] sm:h-7 sm:w-7"
    style="box-shadow: 0px 0px 0.468888px 0.468888px rgba(0, 0, 0, 0.07), 0px 0px 0.468888px 1.40666px rgba(0, 0, 0, 0.05), 0px 5.62666px 6.09555px -2.81333px rgba(0, 0, 0, 0.25), 0px 1.87555px 7.50221px 1.87555px rgba(0, 0, 0, 0.12);"
  >
    <div class="h-full w-full rounded-full bg-gradient-to-b from-[#F4F4F4] to-[#FEFEFE]"></div>
  </div>
  <!-- Content overlay -->
  <div class="hero-grid-content">
    <div class="relative mb-4 space-y-4 sm:space-y-6">
      <h1 class="mb-4 max-w-[700px] mx-auto text-center text-[clamp(1.9rem,8.5vw,3.75rem)] font-bold leading-tight text-black pb-2">
        <span class="fluid-word" style="animation-delay: 0.1s">The</span>
        <span class="fluid-word" style="animation-delay: 0.2s">Overnight</span>
        <span class="fluid-word" style="animation-delay: 0.3s">CTO</span>
      </h1>
      <p class="mb-8 text-center text-sm font-semibold leading-relaxed text-[#64748B] sm:text-xl fade-in-up" style="animation-delay: 0.5s">
        A product lead, a designer and an engineer behind your idea, working as your in house product team toward one shared goal: your first 100 paying users.
      </p>
    </div>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4 sm:mt-11 fade-in-up" style="animation-delay: 0.7s">
      <a href={BOOK_CALL} target="_blank" class="btn">Book a free discovery call</a>
      <a href="https://crework-founderos.vercel.app/" 
   class="btn !bg-white !text-black border border-gray-200 shadow-sm hover:!bg-gray-50" 
   target="_blank" 
   rel="noopener noreferrer">
   Validate your idea
</a>

    </div>
  </div>
</section>

<style>
  .hero-grid-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-grid-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .hero-grid-content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    padding: 20px 0;
    text-align: center;
  }

  .fluid-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(30px);
    animation: fluidReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fluidReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fluidReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById('hero-grid-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const CELL_SIZE = 48;
    const GAP = 1;
    const MOUSE_RADIUS = 160;
    const BASE_ALPHA = 0.04;
    const HOVER_ALPHA = 0.22;
    const BASE_SCALE = 1;
    const HOVER_SCALE = 1.15;

    let mouse = { x: -9999, y: -9999 };
    let cols = 0, rows = 0;
    let cells: { x: number; y: number; currentAlpha: number; currentScale: number; breathOffset: number }[] = [];

    function resize() {
      const section = canvas.parentElement;
      if (!section) return;
      const rect = section.getBoundingClientRect();
      canvas.width = rect.width;
      canvas.height = rect.height;

      cols = Math.ceil(canvas.width / (CELL_SIZE + GAP)) + 1;
      rows = Math.ceil(canvas.height / (CELL_SIZE + GAP)) + 1;

      cells = [];
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          cells.push({
            x: c * (CELL_SIZE + GAP),
            y: r * (CELL_SIZE + GAP),
            currentAlpha: BASE_ALPHA,
            currentScale: BASE_SCALE,
            breathOffset: Math.random() * Math.PI * 2,
          });
        }
      }
    }

    function draw(time: number) {
      if (!ctx) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      const breathCycle = time * 0.001;

      for (const cell of cells) {
        const cx = cell.x + CELL_SIZE / 2;
        const cy = cell.y + CELL_SIZE / 2;
        const dx = mouse.x - cx;
        const dy = mouse.y - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);

        // Mouse proximity factor (0 = far, 1 = on top)
        const proximity = Math.max(0, 1 - dist / MOUSE_RADIUS);
        const easedProximity = proximity * proximity;

        // Breathing animation
        const breath = Math.sin(breathCycle * 1.5 + cell.breathOffset) * 0.5 + 0.5;
        const breathAlpha = BASE_ALPHA + breath * 0.03;

        // Target values
        const targetAlpha = breathAlpha + easedProximity * (HOVER_ALPHA - BASE_ALPHA);
        const targetScale = BASE_SCALE + easedProximity * (HOVER_SCALE - BASE_SCALE);

        // Smooth interpolation
        cell.currentAlpha += (targetAlpha - cell.currentAlpha) * 0.12;
        cell.currentScale += (targetScale - cell.currentScale) * 0.12;

        const s = CELL_SIZE * cell.currentScale;
        const offsetX = (CELL_SIZE - s) / 2;
        const offsetY = (CELL_SIZE - s) / 2;

        ctx.fillStyle = `rgba(0, 0, 0, ${cell.currentAlpha})`;
        ctx.fillRect(cell.x + offsetX, cell.y + offsetY, s, s);
      }

      // Draw grid lines
      ctx.strokeStyle = 'rgba(0, 0, 0, 0.06)';
      ctx.lineWidth = 0.5;

      for (let c = 0; c <= cols; c++) {
        const x = c * (CELL_SIZE + GAP);
        ctx.beginPath();
        ctx.moveTo(x, 0);
        ctx.lineTo(x, canvas.height);
        ctx.stroke();
      }
      for (let r = 0; r <= rows; r++) {
        const y = r * (CELL_SIZE + GAP);
        ctx.beginPath();
        ctx.moveTo(0, y);
        ctx.lineTo(canvas.width, y);
        ctx.stroke();
      }

      requestAnimationFrame(draw);
    }

    // Mouse tracking relative to canvas
    const section = canvas.parentElement;
    if (section) {
      section.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = canvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
      });

      section.addEventListener('mouseleave', () => {
        mouse.x = -9999;
        mouse.y = -9999;
      });
    }

    resize();
    window.addEventListener('resize', resize);
    requestAnimationFrame(draw);
  });
</script>
