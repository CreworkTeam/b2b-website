---
import { Image } from 'astro:assets';
import { BOOK_CALL } from '@/constants.ts';
import Increment from '@/components/react/increment';
import Marquee from '@/components/marquee.astro';

const companies = [
  { src: '/companies/north-star-digital.svg', alt: 'North Star Digital' },
  { src: '/companies/feel-good-club.svg', alt: 'Feel Good Club' },
  { src: '/companies/butterflies.svg', alt: 'Butterflies' },
  { src: '/companies/fundsfinder.svg', alt: 'fundsfinder' },
  { src: '/companies/travaygroup.svg', alt: 'travaygroup' },
  { src: '/companies/icetribe.svg', alt: 'icetribe' },
  { src: '/companies/sriman-swarup.svg', alt: 'sriman swarup' },
  { src: '/companies/onconexus.svg', alt: 'onconexus' },
];
---

<section id="our-impact" class="section-container" data-section="impact">
  <div
    class="absolute left-0 top-0 h-3 w-3 -translate-x-1/2 -translate-y-1/2 rounded-full bg-gradient-to-b from-white to-[#ECECEC] p-[2px] sm:h-7 sm:w-7"
    style="box-shadow: 0px 0px 0.468888px 0.468888px rgba(0, 0, 0, 0.07), 0px 0px 0.468888px 1.40666px rgba(0, 0, 0, 0.05), 0px 5.62666px 6.09555px -2.81333px rgba(0, 0, 0, 0.25), 0px 1.87555px 7.50221px 1.87555px rgba(0, 0, 0, 0.12);"
  >
    <div class="h-full w-full rounded-full bg-gradient-to-b from-[#F4F4F4] to-[#FEFEFE]"></div>
  </div>
  <div
    class="absolute right-0 top-0 m-0 h-3 w-3 -translate-y-1/2 translate-x-1/2 rounded-full bg-gradient-to-b from-white to-[#ECECEC] p-[2px] sm:h-7 sm:w-7"
    style="box-shadow: 0px 0px 0.468888px 0.468888px rgba(0, 0, 0, 0.07), 0px 0px 0.468888px 1.40666px rgba(0, 0, 0, 0.05), 0px 5.62666px 6.09555px -2.81333px rgba(0, 0, 0, 0.25), 0px 1.87555px 7.50221px 1.87555px rgba(0, 0, 0, 0.12);"
  >
    <div class="h-full w-full rounded-full bg-gradient-to-b from-[#F4F4F4] to-[#FEFEFE]"></div>
  </div>
  <div class="space-y-6 sm:space-y-12">
    <h2 class="text-center text-xl font-semibold sm:text-3xl lg:text-start">
      Delivering Results That Drive Growth Across Industries
    </h2>
    <div class="flex flex-col items-center justify-between gap-12 lg:flex-row">
      <div class="flex-[3] min-w-0 space-y-6 md:space-y-12">
        <div class="flex h-fit flex-wrap justify-center gap-2 sm:gap-3 lg:justify-start">
          {
            ['Education', 'E-Commerce', 'Fintech', 'Healthcare', 'SaaS','Enterprise Ops'].map((t) => (
              <span
                style={{
                  border: '1px solid transparent',
                  background:
                    'linear-gradient(white, white) padding-box, linear-gradient(180deg, #E7E7E7 0%, #C6C6C6 100%) border-box',
                }}
                class="rounded-md p-3 text-center text-xs text-[#334155] sm:text-[16px] md:w-[150px]"
              >
                {t}
              </span>
            ))
          }
        </div>
        <div class="mt-4 space-y-4">
          <p class="text-center text-sm font-[500] sm:text-start">Trusted by brands like</p>
          <div class="overflow-hidden rounded-lg border border-[#F1F1F1]">
            <Marquee>
              {
                companies.map((company) => (
                  <div class="flex h-12 w-[110px] min-w-[110px] items-center justify-center border-r border-[#F1F1F1] sm:w-[140px] sm:min-w-[140px]">
                    <Image
                      width={10}
                      height={10}
                      src={company.src}
                      alt={company.alt}
                      class="size-full w-8/12 object-contain"
                    />
                  </div>
                ))
              }
            </Marquee>
          </div>
        </div>
      </div>
      <div
        class="flex h-fit w-full flex-col items-center space-y-3 md:w-8/12 lg:w-6/12 lg:flex-[2]"
      >
        {
          [
            {
              number: '25',
              text: 'Projects Built',
            },
            {
              number: '16',
              text: 'Clients',
            },
            {
              number: '9',
              text: 'Industries',
            },
          ].map(({ number, text }, index) => (
            <div
              class:list={[
                'h-16 w-8/12 max-w-48 flex-1 rounded-lg bg-gray-500 bg-gradient-to-l from-[#FFFFFF] to-[#ECECEC] p-[1px]',
                {
                  'translate-x-1/4 -rotate-6': index === 0 || index === 2,
                  '-translate-x-1/4 rotate-3': index === 1,
                },
              ]}
              style="box-shadow: 0px 0px 0.287412px 0.287412px rgba(0, 0, 0, 0.07), 0px 0px 0.287412px 0.862234px rgba(0, 0, 0, 0.05), 0px 3.44894px 3.73635px -1.72447px rgba(0, 0, 0, 0.25), 0px 1.14965px 4.59858px 1.14965px rgba(0, 0, 0, 0.12);"
            >
              <div class="relative flex h-full items-center justify-center rounded-lg bg-gradient-to-l from-[#F4F4F4] to-[#FEFEFE]">
                <div
                  class="absolute left-2 top-2 h-1 w-1 rounded-full bg-[#D9D9D9]"
                  style="box-shadow: inset 0px 1.04771px 1.04771px rgba(0, 0, 0, 0.15);"
                />
                <div
                  class="absolute right-2 top-2 h-1 w-1 rounded-full bg-[#D9D9D9]"
                  style="box-shadow: inset 0px 1.04771px 1.04771px rgba(0, 0, 0, 0.15);"
                />
                <div
                  class="absolute bottom-2 left-2 h-1 w-1 rounded-full bg-[#D9D9D9]"
                  style="box-shadow: inset 0px 1.04771px 1.04771px rgba(0, 0, 0, 0.15);"
                />
                <div
                  class="absolute bottom-2 right-2 h-1 w-1 rounded-full bg-[#D9D9D9]"
                  style="box-shadow: inset 0px 1.04771px 1.04771px rgba(0, 0, 0, 0.15);"
                />
                <p class="font-insrument-serif inline-block w-full bg-clip-text p-2 pr-1 text-center text-xl text-transparent sm:p-3 sm:text-2xl">
                  <Increment number={parseInt(number)} client:only="react" />+ {text}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
  <a
    href={BOOK_CALL}
    target="_blank"
    class="btn mx-auto mt-8 block text-center sm:mx-0 md:w-fit md:px-14"
  >
    Book a free discovery call
  </a>
</section>
