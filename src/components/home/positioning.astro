---
import Section from '../section.astro';
---

<Section id="positioning" data-section="positioning" className="py-24">
  <div class="relative mx-auto max-w-5xl overflow-hidden rounded-[2.5rem] border border-[#EAEAEA] bg-white px-8 py-16 text-center shadow-[0_8px_30px_rgb(0,0,0,0.08)] md:px-16 md:py-24">
    <div class="relative z-10 mx-auto max-w-4xl flex flex-col items-center justify-center">
      
      {/* The 3 Evenly Spaced Subheadings */}
      <div class="flex w-full flex-col items-center gap-8 md:gap-12">
        <h3 class="text-balance text-2xl font-medium text-black md:text-4xl leading-relaxed">
          A dev shop builds what you tell it to.
        </h3>
        
        <h3 class="text-balance text-2xl font-medium text-black md:text-4xl leading-relaxed">
          We decide with you what's worth building, design every screen to convert and ship in weeks.
        </h3>
        
        <h3 class="text-balance text-2xl font-medium text-black md:text-4xl leading-relaxed">
          Less like a vendor, more like the technical cofounder you haven't hired.
        </h3>
      </div>
      
    </div>
  </div>
</Section>