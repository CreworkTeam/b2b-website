---
import { cn } from '@/lib/utils';
import Section from '../section.astro';
import { Image } from 'astro:assets';
---

<Section data-section="how-we-work" className="space-y-12">
  <div class="space-y-3 text-center">
    <h2 class="font-semibold text-3xl md:text-4xl">How we work</h2>
    <p class="text-lg text-gray-600">Your in house product team, from first call to paying users.</p>
  </div>
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    {
      [
        {
          title: 'Brainstorm and scope.',
          text: 'One working session. We pressure test the idea, decide together which features actually matter and lock scope. You know exactly what\'s being built and why.',
          src: '/how-we-work/initial.svg',
        },
        {
          title: 'Design for conversion.',
          text: 'We design the experience end to end. Clean, intuitive and built so the users who land actually convert.',
          src: '/how-we-work/competitor.svg',
        },
        {
          title: 'Launch in weeks.',
          text: 'We build and ship your web or mobile app in 3 to 4 weeks. Weekly demos. No black box.',
          src: '/how-we-work/implementation.svg',
        },
        {
          title: 'Iterate toward paying users.',
          text: 'Launch is the starting line. We sit in the data with you, decide what to build next and ship weekly. Every decision aimed at the same goal: users who pay.',
          src: '/how-we-work/post-launch.svg',
        },
      ].map(({ title, text, src }) => (
        <div class="flex size-full flex-col justify-between space-y-4 rounded-3xl border border-[#C1C1C1] px-6 py-8 text-center md:px-10">
          <div class="space-y-2">
            <h5 class="text-xl font-semibold text-[#333333]">{title}</h5>
            <p class="text-[#666666] leading-relaxed">{text}</p>
          </div>
          <div class="flex h-48 items-center justify-center">
            <Image
              src={src}
              alt={title}
              class="h-full w-10/12 object-contain sm:w-full"
              width={400}
              height={400}
            />
          </div>
        </div>
      ))
    }
  </div>
</Section>
