---
import Section from '../section.astro';
---

<Section id="lead-magnet" data-section="lead-magnet" className="py-24">
  <div class="relative mx-auto max-w-5xl overflow-hidden rounded-[2.5rem] border border-[#EAEAEA] bg-white px-8 py-16 text-center shadow-[0_8px_30px_rgb(0,0,0,0.08)] md:px-16 md:py-24">
    <div class="relative z-10 mx-auto max-w-4xl space-y-8">
      <h2 class="text-balance text-3xl font-bold md:text-5xl lg:leading-[1.15] text-transparent bg-clip-text bg-gradient-to-r from-[#111111] to-[#777777]">
        Not sure your idea is ready? <br class="hidden md:block" />
        Prove it first.
      </h2>
      <p class="mx-auto max-w-3xl text-balance text-lg text-[#666666] md:text-xl md:leading-relaxed">
        <span class="text-[#111111] font-semibold">Founder OS</span> is our free tool that takes your raw idea and shows you the real conversations already happening around it. Exact posts and discussions where your future users are describing the problem, plus a scoped plan for what to build first.
      </p>
      
      <a href="#" class="btn mx-auto mt-8 block w-fit px-10 py-4 text-center text-lg font-semibold transition-transform hover:scale-[1.02] bg-[#111111] text-white hover:bg-black rounded-xl">
        Validate your idea
      </a>
    </div>
  </div>
</Section>
