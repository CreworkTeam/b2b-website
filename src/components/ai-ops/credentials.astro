---
const credsList = ['Stanford', 'UPenn', 'Meta', 'Amazon', 'Adobe', 'UC Berkeley', 'JPMC', 'Daimler', 'Springworks'];
---
<div class="creds">
  <div class="container">
    <p class="creds-label reveal">Built by a team from</p>
  </div>
  <div class="marquee reveal" aria-label="Team credentials">
    <div class="marquee-track">
      {credsList.map((c) => <span>{c}</span>)}
      {credsList.map((c) => <span aria-hidden="true">{c}</span>)}
    </div>
  </div>
</div>
