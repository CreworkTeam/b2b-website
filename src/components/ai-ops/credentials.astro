---
const credsList = ['Stanford', 'UPenn', 'Meta', 'Amazon', 'Adobe', 'UC Berkeley', 'Walmart', 'Daimler', 'Springworks'];
---
<div class="creds">
  <div class="container">
    <p class="creds-label reveal">Built by a team from</p>
  </div>
  <div class="marquee reveal" aria-label="Team credentials">
    <div class="marquee-track">
      {credsList.map((c) => (
        c === 'Walmart' ? (
          <span class="logo-wrapper inline-flex items-center justify-center">
            <img src="/Walmart.png" alt="Walmart" class="h-[38px] w-auto opacity-35 hover:opacity-85 transition-opacity filter grayscale brightness-[3]" style="vertical-align: middle;" />
          </span>
        ) : (
          <span>{c}</span>
        )
      ))}
      {credsList.map((c) => (
        c === 'Walmart' ? (
          <span aria-hidden="true" class="logo-wrapper inline-flex items-center justify-center">
            <img src="/Walmart.png" alt="Walmart" class="h-[38px] w-auto opacity-35 hover:opacity-85 transition-opacity filter grayscale brightness-[3]" style="vertical-align: middle;" />
          </span>
        ) : (
          <span aria-hidden="true">{c}</span>
        )
      ))}
    </div>
  </div>
</div>
