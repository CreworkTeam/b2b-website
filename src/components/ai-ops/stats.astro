---
<div class="stats">
  <div class="container">
    <div class="stats-grid">
      <div class="reveal">
        <div class="stat-num"><span class="count" data-target="1000">0</span>+</div>
        <p class="stat-cap">hours of manual work eliminated across client operations</p>
      </div>
      <div class="reveal">
        <div class="stat-num"><span class="count" data-target="25">0</span>+</div>
        <p class="stat-cap">systems in production across 9 industries</p>
      </div>
      <div class="reveal">
        <div class="stat-num" style="white-space: nowrap;">Up to <span class="count" data-target="50">0</span>%</div>
        <p class="stat-cap">of team capacity recovered</p>
      </div>
    </div>
  </div>
</div>
